generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  telepules   String
  countryCode String
  lat         Float?
  lon         Float?
  budget      Int?
  note        String?
  createdAt   DateTime @default(now())

  @@map("customers")
}
